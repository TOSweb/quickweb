
<script src="https://cdn.tailwindcss.com"></script>
<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');

    .servicedown-root {
        font-family: 'Inter', sans-serif;
    }

    .gradient-bg {
        background: linear-gradient(-45deg, #1e40af, #3b82f6, #06b6d4, #0891b2);
        background-size: 400% 400%;
        animation: gradientShift 15s ease infinite;
    }

    @keyframes gradientShift {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    .floating {
        animation: floating 6s ease-in-out infinite;
    }

    @keyframes floating {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-20px); }
    }

    .pulse-glow {
        animation: pulseGlow 2s ease-in-out infinite alternate;
    }

    @keyframes pulseGlow {
        from { box-shadow: 0 0 20px rgba(59, 130, 246, 0.3); }
        to   { box-shadow: 0 0 40px rgba(59, 130, 246, 0.6); }
    }

    .typewriter {
        overflow: hidden;
        border-right: 2px solid #3b82f6;
        white-space: nowrap;
        animation: typing 3s steps(40, end), blink 0.75s step-end infinite;
    }

    @keyframes typing {
        from { width: 0; }
        to   { width: 100%; }
    }

    @keyframes blink {
        from, to { border-color: transparent; }
        50%      { border-color: #3b82f6; }
    }

    .glass-effect {
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    }
</style>
<div class="servicedown-root gradient-bg min-h-screen flex items-center justify-center p-4">
    <div class="glass-effect rounded-3xl p-8 md:p-12 max-w-2xl w-full text-center text-white shadow-2xl">
        <!-- Logo/Brand Area -->
        <div class="floating mb-8">
            <div class="w-24 h-24 mx-auto bg-white/20 rounded-full flex items-center justify-center mb-4 pulse-glow">
                <img src="https://theonesolution.co.in/assets/logo.svg" alt="">
            </div>
            <h1 class="text-3xl md:text-4xl font-bold mb-2">The One Solution</h1>
        </div>
        
        <!-- Main Message -->
        <div class="mb-8">
            <h2 class="text-2xl md:text-3xl font-semibold mb-4 typewriter">Major Update Coming Soon!</h2>
            <p class="text-lg md:text-xl text-white/90 leading-relaxed mb-6">
                We're working hard to bring you an amazing new experience. Our website is currently undergoing a major update to serve you better.
            </p>
            <div class="flex items-center justify-center space-x-2 text-white/80">
                <div class="w-2 h-2 bg-white rounded-full animate-bounce"></div>
                <div class="w-2 h-2 bg-white rounded-full animate-bounce" style="animation-delay: 0.1s;"></div>
                <div class="w-2 h-2 bg-white rounded-full animate-bounce" style="animation-delay: 0.2s;"></div>
                <span class="ml-3 text-sm">Building something extraordinary</span>
            </div>
        </div>
        
        <!-- Contact Information -->
        <div class="bg-white/10 rounded-2xl p-6 mb-8 backdrop-blur-sm">
            <h3 class="text-xl font-semibold mb-4 text-white">Get In Touch</h3>
            <div class="space-y-4">
                <a href="tel:8088519842" 
                   class="hover-lift flex items-center justify-center space-x-3 bg-white/20 rounded-lg p-4 hover:bg-white/30 transition-all duration-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                    </svg>
                    <span class="font-medium">808 851 9842</span>
                </a>
                
                <a href="mailto:hello@theonesolution.co.in" 
                   class="hover-lift flex items-center justify-center space-x-3 bg-white/20 rounded-lg p-4 hover:bg-white/30 transition-all duration-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    <span class="font-medium">hello@theonesolution.co.in</span>
                </a>
            </div>
        </div>
        
        <!-- Progress Indicator -->
        <div class="mb-6">
            <div class="flex justify-between text-sm text-white/80 mb-2">
                <span>Progress</span>
                <span id="progressText">75%</span>
            </div>
            <div class="w-full bg-white/20 rounded-full h-2">
                <div id="progressBar" class="bg-gradient-to-r from-blue-400 to-cyan-400 h-2 rounded-full transition-all duration-1000 ease-out" style="width: 75%"></div>
            </div>
        </div>
        
        <!-- Footer -->
        <p class="text-white/70 text-sm">
            Thank you for your patience. We'll be back soon with something amazing!
        </p>
    </div>

    <script>
        // Animate progress bar on load
        window.addEventListener('load', function() {
            const progressBar = document.getElementById('progressBar');
            const progressText = document.getElementById('progressText');
            
            // Start from 0 and animate to 75%
            setTimeout(() => {
                progressBar.style.width = '75%';
            }, 500);
            
            // Add some random progress updates for visual interest
            let currentProgress = 75;
            setInterval(() => {
                // Randomly increase progress by 1-3%
                const increase = Math.floor(Math.random() * 3) + 1;
                currentProgress = Math.min(95, currentProgress + increase);
                
                progressBar.style.width = currentProgress + '%';
                progressText.textContent = currentProgress + '%';
            }, 10000); // Update every 10 seconds
        });
        
        // Add click effects to contact buttons
        document.querySelectorAll('a[href^="tel:"], a[href^="mailto:"]').forEach(link => {
            link.addEventListener('click', function(e) {
                // Add a visual feedback
                this.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    this.style.transform = '';
                }, 150);
            });
        });
        
        // Add particle effect (optional enhancement)
        function createParticle() {
            const particle = document.createElement('div');
            particle.className = 'fixed w-1 h-1 bg-white/30 rounded-full pointer-events-none';
            particle.style.left = Math.random() * window.innerWidth + 'px';
            particle.style.top = window.innerHeight + 'px';
            particle.style.animation = 'float-up 8s linear forwards';
            document.body.appendChild(particle);
            
            setTimeout(() => {
                particle.remove();
            }, 8000);
        }
        
        // Add floating particles CSS animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes float-up {
                to {
                    transform: translateY(-${window.innerHeight + 100}px) rotate(360deg);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
        
        // Create particles periodically
        setInterval(createParticle, 3000);
    </script>
</div>
