<!-- themes/default/components/hero/template.njk -->
<section class="hero-section" style="background: #f8fafc; padding: 100px 20px; text-align: center;">
    <div class="container">
        <h1 class="editable" data-field="title">{{ title }}</h1>
        <p class="editable" data-field="subtitle" style="font-size: 1.2rem; color: #64748b; margin: 20px 0;">{{ subtitle }}</p>
        {% if button_text %}
        <a href="{{ button_url }}" class="btn btn-primary" data-field="button_text">{{ button_text }}</a>
        {% endif %}
    </div>
</section>

<style>
.hero-section h1 { font-size: 3rem; font-weight: 800; color: #1e293b; }
.hero-section .btn { display: inline-block; padding: 12px 24px; background: #4f46e5; color: white; border-radius: 8px; text-decoration: none; font-weight: 600; margin-top: 30px; }
</style>
